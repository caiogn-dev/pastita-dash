# URL base da API backend (sem barra final)
VITE_API_URL=https://backend.pastita.com.br/api/v1

# URL do servidor WebSocket (sem caminho, apenas protocolo + host)
VITE_WS_URL=wss://backend.pastita.com.br

# Slug padrão da loja/tenant (usado como fallback)
VITE_STORE_SLUG=pastita

# Chave da API do Google Maps (necessária para zonas de entrega)
VITE_GOOGLE_MAPS_KEY=
