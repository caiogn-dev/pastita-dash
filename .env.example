# URL base da API backend (sem barra final)
VITE_API_URL=https://backend.pastita.com.br/api/v1

# URL do servidor WebSocket (base origin only, sem /ws)
VITE_WS_URL=wss://backend.pastita.com.br

# Slug padrão da loja/tenant (opcional; SaaS multi-tenant deve preferir loja selecionada)
VITE_STORE_SLUG=

# Base pública dos cardápios
VITE_STOREFRONT_BASE_URL=https://cardapidex.com.br

# Chave da API do Google Maps (necessária para zonas de entrega)
VITE_GOOGLE_MAPS_KEY=
